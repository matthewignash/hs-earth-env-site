<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} · {{ site.fullName }}{% else %}{{ site.fullName }}{% endif %}</title>
  {% if description %}<meta name="description" content="{{ description }}">{% endif %}
  <link rel="stylesheet" href="/assets/styles.css">
  {% if extraStylesheets %}{% for href in extraStylesheets %}<link rel="stylesheet" href="{{ href }}">{% endfor %}{% endif %}
</head>
<body>

<nav class="topnav" aria-label="Primary">
  <a class="brand" href="/">{{ site.name }}</a>
  {%- for item in nav %}
    {%- set isActive = page.url | isActiveNav(item.match) %}
    <a href="{{ item.url }}"
       class="{% if item.className %}{{ item.className }}{% endif %}{% if isActive %} active{% endif %}"
       {% if isActive %}aria-current="page"{% endif %}>
      {{ item.label }}
    </a>
    {%- if loop.index == 1 %}<span class="spacer"></span>{% endif %}
  {%- endfor %}
</nav>

{% if customLayout %}
{{ content | safe }}
{% else %}
<header class="page-header">
  <div class="container">
    <h1>{{ title }}</h1>
    {% if tagline %}<p class="tagline">{{ tagline }}</p>{% endif %}
  </div>
</header>

<main class="container">
  {{ content | safe }}
</main>
{% endif %}

<footer class="site-footer">
  {{ site.fullName }} · AY {{ site.year }}
</footer>

</body>
</html>
