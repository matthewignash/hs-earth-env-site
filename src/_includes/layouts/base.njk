<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} · {{ site.fullName }}{% else %}{{ site.fullName }}{% endif %}</title>
  {% if description %}<meta name="description" content="{{ description }}">{% endif %}
  <meta property="og:title" content="{% if title %}{{ title }} · {{ site.fullName }}{% else %}{{ site.fullName }}{% endif %}">
  {% if description or tagline %}<meta property="og:description" content="{{ description or tagline }}">{% endif %}
  <meta property="og:type" content="website">
  <meta name="twitter:card" content="summary">
  <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg">
  <link rel="stylesheet" href="/assets/styles.css">
  {% if extraStylesheets %}{% for href in extraStylesheets %}<link rel="stylesheet" href="{{ href }}">{% endfor %}{% endif %}
</head>
<body>

<a class="skip-link" href="#main">Skip to main content</a>

<nav class="topnav" aria-label="Primary">
  <a class="brand" href="/">{{ site.name }}</a>
  {%- for item in nav %}
    {%- set isActive = page.url | isActiveNav(item.match) %}
    <a href="{{ item.url }}"
       class="{% if item.className %}{{ item.className }}{% endif %}{% if isActive %} active{% endif %}"
       {% if isActive %}aria-current="page"{% endif %}>
      {{ item.label }}
    </a>
    {%- if loop.index == 1 %}<span class="spacer"></span>{% endif %}
  {%- endfor %}
</nav>

{% if customLayout %}
<main id="main">
{{ content | safe }}
</main>
{% else %}
{% include "partials/breadcrumbs.njk" %}

{% if heroLayout %}
<header class="home-hero">
  <div class="container">
    <h1>{{ title }}</h1>
    {% if tagline %}<p class="hero-tagline">{{ tagline }}</p>{% endif %}
  </div>
</header>
{% else %}
<header class="page-header">
  <div class="container">
    <h1>{{ title }}</h1>
    {% if tagline %}<p class="tagline">{{ tagline }}</p>{% endif %}
  </div>
</header>
{% endif %}

<main id="main" class="container">
  {% if returnTo %}
  <p class="lesson-return">← Back to {% for r in returnTo %}{% if not loop.first %} · {% endif %}<a href="{{ r.url }}">{{ r.label }}</a>{% endfor %}</p>
  {% endif %}
  {{ content | safe }}
  {% if returnTo %}
  <div class="lesson-return-bottom">
    <span>Done here? Back to the lesson:</span>
    {% for r in returnTo %}<a href="{{ r.url }}">← {{ r.label }}</a>{% endfor %}
  </div>
  {% endif %}
</main>
{% endif %}

<footer class="site-footer">
  <nav class="site-footer-nav" aria-label="Footer">
    {%- for item in nav %}
      <a href="{{ item.url }}">{{ item.label }}</a>
    {%- endfor %}
  </nav>
  <div class="site-footer-meta">{{ site.fullName }} · AY {{ site.year }}</div>
</footer>

</body>
</html>
