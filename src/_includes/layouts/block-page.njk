---
layout: layouts/base.njk
customLayout: true
extraStylesheets:
  - /assets/block-page.css
---

{% include "partials/breadcrumbs.njk" %}

<header class="page-header">
  <div class="container">
    <h1>Block {{ block }} — {{ title }}</h1>
    <div class="meta">
      <span>Unit {{ unit }} · Block {{ block }} of {{ blocksTotal }}</span>
      {% if minutes %}<span>⏰ {{ minutes }} minutes</span>{% endif %}
      {% if week and day %}<span>Week {{ week }}, Day {{ day }}</span>{% endif %}
    </div>
    {% if strands %}
    <div class="strand-chips">
      <span class="label">Today builds toward:</span>
      {%- for s in strands.active %}<span class="chip active">{{ s }}</span>{% endfor %}
      {%- for s in strands.preview %}<span class="chip preview">{{ s }} (preview)</span>{% endfor %}
      {%- for s in strands.faded %}<span class="chip faded">{{ s }}</span>{% endfor %}
    </div>
    {% endif %}
  </div>
</header>

<main class="container">

  {% if bellRinger %}
  <div class="bell-ringer">
    <div class="bell-ringer-head">Bell ringer — start here (while attendance happens)</div>
    <div class="bell-ringer-meta">{{ bellRinger.tag }} · {{ bellRinger.minutes }} min</div>
    <p>{{ bellRinger.text | safe }}</p>
    <p class="bell-ringer-journal">Answer in your Reflection Journal — dated.</p>
  </div>
  {% endif %}

  {% if aiPartners %}
  <div class="ai-callout">
    <div class="ai-label">AI Partners available for today's work</div>
    <div class="ai-partners">
      {%- for p in aiPartners %}
      <a href="/ai-partners/{{ p.slug }}/" class="ai-partner-link">{{ p.label }}</a>
      {%- endfor %}
    </div>
    <div class="ai-reminder">
      Remember: every AI use gets documented.
      <a href="/student-hub/ai-documentation-template/">→ AI Documentation Template</a>
    </div>
  </div>
  {% endif %}

  {{ content | safe }}

  {% if prev or next or unitMapUrl %}
  <nav class="block-nav" aria-label="Block navigation">
    {% if prev %}
      <a href="{{ prev.url }}">← {{ prev.label }}</a>
    {% else %}
      <span></span>
    {% endif %}
    {% if unitMapUrl %}<a href="{{ unitMapUrl }}" class="map-link">Unit {{ unit }} Map</a>{% endif %}
    {% if next %}
      <a href="{{ next.url }}">{{ next.label }} →</a>
    {% else %}
      <span></span>
    {% endif %}
  </nav>
  {% endif %}

  {% if standards %}
  <p class="standards-footer">This block builds — {% if standards.ngss and standards.ngss.length %}NGSS: {{ standards.ngss | join(" · ") }}{% endif %}{% if standards.ngss and standards.ngss.length and standards.ailit and standards.ailit.length %} | {% endif %}{% if standards.ailit and standards.ailit.length %}AI Literacy (OECD AILit): {{ standards.ailit | join(" · ") }}{% endif %} · <a href="/foundations/standards-map/">full course map</a></p>
  {% endif %}

</main>
