---
layout: layouts/base.njk
customLayout: true
extraStylesheets:
  - /assets/block-page.css
---

{% macro stdChip(s, cls) %}
  {%- set sid = s | baseStandardId -%}
  {%- set entry = standardsCatalog[sid] -%}
  {%- if entry -%}
  <button type="button" class="std-chip {{ cls }}" data-panel="std-panel-{{ sid | slugify }}" aria-expanded="false" aria-controls="std-panel-{{ sid | slugify }}">{{ 'NGSS' if cls == 'ngss' else 'AILit' }} {{ s }}</button>
  {%- else -%}
  <a class="std-chip {{ cls }}" href="/foundations/standards-map/">{{ 'NGSS' if cls == 'ngss' else 'AILit' }} {{ s }}</a>
  {%- endif -%}
{% endmacro %}
{% macro stdPanel(s, cls) %}
  {%- set sid = s | baseStandardId -%}
  {%- set entry = standardsCatalog[sid] -%}
  {%- if entry -%}
  <div class="std-panel" id="std-panel-{{ sid | slugify }}" hidden>
    <p class="std-plain"><strong>{{ entry.plain }}</strong></p>
    <p class="std-official">{% if entry.type == 'ailit' %}In brief: {% endif %}"{{ entry.official }}"</p>
    {%- set trail = collections.standardsBlocks | standardsTrail(sid) -%}
    {%- if trail.length %}
    <p class="std-label">Where this runs:</p>
    <ul class="std-trail">
      {%- for t in trail %}
      <li>{% if t.url == page.url %}<span class="std-here">U{{ t.unit }} B{{ t.block }} — {{ t.title }} ← you are here</span>{% else %}<a href="{{ t.url }}">U{{ t.unit }} B{{ t.block }} — {{ t.title }}</a>{% endif %}</li>
      {%- endfor %}
    </ul>
    {%- endif %}
    <p class="std-label">Assessed:</p>
    <p>{{ entry.assessedAt }}</p>
    <p class="std-label">On track looks like:</p>
    <p>{{ entry.onTrack }}</p>
    {%- if entry.help.length %}
    <p class="std-help">{% for h in entry.help %}{% if h.url %}<a href="{{ h.url }}">{{ h.label }}</a>{% else %}<span>{{ h.label }}</span>{% endif %}{% if not loop.last %} · {% endif %}{% endfor %}</p>
    {%- endif %}
  </div>
  {%- endif -%}
{% endmacro %}
{% include "partials/breadcrumbs.njk" %}

<header class="page-header">
  <div class="container">
    <h1>Block {{ block }} — {{ title }}</h1>
    <div class="meta">
      <span>Unit {{ unit }} · Block {{ block }} of {{ blocksTotal }}</span>
      {% if minutes %}<span>⏰ {{ minutes }} minutes</span>{% endif %}
      {% if week and day %}<span>Week {{ week }}, Day {{ day }}</span>{% endif %}
    </div>
    {% if strands %}
    <div class="strand-chips">
      <span class="label">Today builds toward:</span>
      {%- for s in strands.active %}<span class="chip active">{{ s }}</span>{% endfor %}
      {%- for s in strands.preview %}<span class="chip preview">{{ s }} (preview)</span>{% endfor %}
      {%- for s in strands.faded %}<span class="chip faded">{{ s }}</span>{% endfor %}
    </div>
    {% endif %}
  </div>
</header>

<main class="container">

  {% if bellRinger %}
  <div class="bell-ringer">
    <div class="bell-ringer-head">Bell ringer — start here (while attendance happens)</div>
    <div class="bell-ringer-meta">{{ bellRinger.tag }} · {{ bellRinger.minutes }} min</div>
    <p>{{ bellRinger.text | safe }}</p>
    {% if bellRinger.image %}
    <figure class="content-figure bell-ringer-figure">
      <img src="{{ bellRinger.image }}" alt="{{ bellRinger.imageAlt }}">
      {% if bellRinger.imageCredit %}<figcaption>{{ bellRinger.imageCredit | safe }}</figcaption>{% endif %}
    </figure>
    {% endif %}
    <p class="bell-ringer-journal">Answer in your Reflection Journal — dated.</p>
  </div>
  {% endif %}

  {% if learningIntention %}
  <section class="learning-panel" id="learning-panel" aria-label="Today's learning target">
    <div class="lp-tag">Today we are learning</div>
    <p class="lp-intention">{{ learningIntention | safe }}</p>
    {% if successCriteria and successCriteria.length %}
    <div class="lp-sc-head"><span>I can — tick as you go (for you, not for marks)</span> <button type="button" class="lp-reset">reset</button></div>
    <ul class="lp-sc-list">
      {%- for sc in successCriteria %}
      <li><label><input type="checkbox" class="lp-check" data-sc-index="{{ loop.index0 }}"><span>{{ sc }}</span></label></li>
      {%- endfor %}
    </ul>
    {% endif %}
    {% if standards and (standards.ngss.length or standards.ailit.length) %}
    <div class="lp-standards">
      {%- for s in standards.ngss %}{{ stdChip(s, 'ngss') }}{% endfor %}
      {%- for s in standards.ailit %}{{ stdChip(s, 'ailit') }}{% endfor %}
      <a class="lp-map-link" href="/foundations/standards-map/">full course map →</a>
    </div>
    {%- for s in standards.ngss %}{{ stdPanel(s, 'ngss') }}{% endfor %}
    {%- for s in standards.ailit %}{{ stdPanel(s, 'ailit') }}{% endfor %}
    {% endif %}
  </section>
  {% endif %}

  {% if aiPartners %}
  <div class="ai-callout">
    <div class="ai-label">AI Partners available for today's work</div>
    <div class="ai-partners">
      {%- for p in aiPartners %}
      <a href="/ai-partners/{{ p.slug }}/" class="ai-partner-link">{{ p.label }}</a>
      {%- endfor %}
    </div>
    <div class="ai-reminder">
      Remember: every AI use gets documented.
      <a href="/student-hub/ai-documentation-template/">→ AI Documentation Template</a>
    </div>
  </div>
  {% endif %}

  {{ content | safe }}

  {% if prev or next or unitMapUrl %}
  <nav class="block-nav" aria-label="Block navigation">
    {% if prev %}
      <a href="{{ prev.url }}">← {{ prev.label }}</a>
    {% else %}
      <span></span>
    {% endif %}
    {% if unitMapUrl %}<a href="{{ unitMapUrl }}" class="map-link">Unit {{ unit }} Map</a>{% endif %}
    {% if next %}
      <a href="{{ next.url }}">{{ next.label }} →</a>
    {% else %}
      <span></span>
    {% endif %}
  </nav>
  {% endif %}

</main>

{% if learningIntention %}
<div class="li-sticky" id="li-sticky" hidden>
  <div class="li-sticky-row container">
    <span class="li-sticky-text">{{ learningIntention | safe }}</span>
    <span class="li-sticky-target">Today's target</span>
    {% if successCriteria and successCriteria.length %}
    <span class="li-sticky-count" aria-live="polite"></span>
    <button type="button" class="li-sticky-toggle" aria-expanded="false" aria-label="Show the success criteria checklist">▾</button>
    {% endif %}
  </div>
  {% if successCriteria and successCriteria.length %}
  <ul class="lp-sc-list li-sticky-list container" hidden>
    {%- for sc in successCriteria %}
    <li><label><input type="checkbox" class="lp-check" data-sc-index="{{ loop.index0 }}"><span>{{ sc }}</span></label></li>
    {%- endfor %}
  </ul>
  {% endif %}
</div>
<script>
(function () {
  var panel = document.getElementById('learning-panel');
  if (!panel) return;
  var bar = document.getElementById('li-sticky');
  var key = 'sc:' + location.pathname;
  var checks = Array.prototype.slice.call(document.querySelectorAll('.lp-check'));
  var total = panel.querySelectorAll('.lp-check').length;
  function load() { try { return JSON.parse(localStorage.getItem(key)) || []; } catch (e) { return []; } }
  function save(st) { try { localStorage.setItem(key, JSON.stringify(st)); } catch (e) {} }
  function apply() {
    var st = load(), n = 0, i;
    checks.forEach(function (c) { c.checked = !!st[c.dataset.scIndex]; });
    for (i = 0; i < total; i++) if (st[i]) n++;
    var count = bar && bar.querySelector('.li-sticky-count');
    if (count) count.textContent = n + '/' + total + ' ✓';
  }
  checks.forEach(function (c) {
    c.addEventListener('change', function () {
      var st = load(); st[c.dataset.scIndex] = c.checked; save(st); apply();
    });
  });
  Array.prototype.forEach.call(document.querySelectorAll('.lp-reset'), function (b) {
    b.addEventListener('click', function () { save([]); apply(); });
  });
  apply();
  if (!bar) return;
  var nav = document.querySelector('.topnav');
  function setTop() { bar.style.top = (nav ? nav.offsetHeight : 0) + 'px'; }
  setTop();
  window.addEventListener('resize', setTop);
  var toggle = bar.querySelector('.li-sticky-toggle');
  var list = bar.querySelector('.li-sticky-list');
  if (toggle && list) {
    toggle.addEventListener('click', function () {
      var opening = list.hidden;
      list.hidden = !opening;
      toggle.setAttribute('aria-expanded', opening ? 'true' : 'false');
      toggle.textContent = opening ? '▴' : '▾';
    });
  }
  if ('IntersectionObserver' in window) {
    new IntersectionObserver(function (entries) {
      var e = entries[0];
      var pastTop = e.boundingClientRect.bottom < (nav ? nav.offsetHeight : 0) + 4;
      var show = !e.isIntersecting && pastTop;
      bar.hidden = !show;
      if (!show && list) { list.hidden = true; if (toggle) { toggle.setAttribute('aria-expanded', 'false'); toggle.textContent = '▾'; } }
    }, { rootMargin: '-60px 0px 0px 0px' }).observe(panel);
  }
})();
(function () {
  var chips = Array.prototype.slice.call(document.querySelectorAll('.std-chip[data-panel]'));
  if (!chips.length) return;
  function close(chip) {
    var p = document.getElementById(chip.dataset.panel);
    if (p) p.hidden = true;
    chip.setAttribute('aria-expanded', 'false');
  }
  chips.forEach(function (chip) {
    chip.addEventListener('click', function () {
      var p = document.getElementById(chip.dataset.panel);
      if (!p) return;
      var opening = p.hidden;
      chips.forEach(close);
      if (opening) { p.hidden = false; chip.setAttribute('aria-expanded', 'true'); }
    });
  });
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') chips.forEach(close);
  });
})();
</script>
{% endif %}
