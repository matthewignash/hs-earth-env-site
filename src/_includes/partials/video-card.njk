{# Video entry card that plays in a lightbox overlay. Set a `video` object before including:
   {% set video = { id: "...", title: "...", cardTitle: "Watch (6 min)", blurb: "...", meta: "Plays here · ~6 min · YouTube" } %}
   {% include "partials/video-card.njk" %}
   No JS → plain link to YouTube. Click → large <dialog> lightbox with nocookie player.
   Closing the lightbox removes the iframe (stops playback). #}
<a class="entry-card video-card" href="https://youtu.be/{{ video.id }}" target="_blank" rel="noopener" data-video-id="{{ video.id }}" data-video-title="{{ video.title }}">
  <span class="video-thumb">
    <img src="https://i.ytimg.com/vi/{{ video.id }}/hqdefault.jpg" alt="Video preview: {{ video.title }}" loading="lazy">
    <span class="video-play" aria-hidden="true">▶</span>
  </span>
  <div class="entry-title">{{ video.cardTitle }}</div>
  <div>{{ video.blurb | safe }}</div>
  <div class="entry-meta">{{ video.meta }}</div>
</a>
<script>
if (!window.__videoCardInit) {
  window.__videoCardInit = true;

  var lightbox = document.createElement('dialog');
  lightbox.className = 'video-lightbox';
  var frameBox = document.createElement('div');
  frameBox.className = 'video-lightbox-frame';
  var bar = document.createElement('div');
  bar.className = 'video-lightbox-bar';
  var ytLink = document.createElement('a');
  ytLink.className = 'video-lightbox-yt';
  ytLink.target = '_blank';
  ytLink.rel = 'noopener';
  ytLink.textContent = 'Watch on YouTube ↗';
  var closeBtn = document.createElement('button');
  closeBtn.className = 'video-lightbox-close';
  closeBtn.setAttribute('aria-label', 'Close video');
  closeBtn.textContent = '✕ Close';
  bar.append(ytLink, closeBtn);
  lightbox.append(frameBox, bar);
  document.body.appendChild(lightbox);

  document.addEventListener('click', function (e) {
    var card = e.target.closest('.video-card');
    if (card) {
      e.preventDefault();
      var frame = document.createElement('iframe');
      frame.src = 'https://www.youtube-nocookie.com/embed/' + card.dataset.videoId + '?autoplay=1';
      frame.allow = 'autoplay; encrypted-media; fullscreen';
      frame.title = card.dataset.videoTitle;
      frameBox.replaceChildren(frame);
      ytLink.href = 'https://youtu.be/' + card.dataset.videoId;
      lightbox.showModal();
      return;
    }
    if (e.target === closeBtn || e.target === lightbox) lightbox.close();
  });

  lightbox.addEventListener('close', function () {
    frameBox.replaceChildren();
  });
}
</script>
