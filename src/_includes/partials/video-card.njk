{# Click-to-play video entry card. Set a `video` object before including:
   {% set video = { id: "...", title: "...", cardTitle: "Watch (6 min)", blurb: "...", meta: "Plays here · ~6 min · YouTube" } %}
   {% include "partials/video-card.njk" %}
   No JS → plain link to YouTube. Click → thumbnail swaps to embedded nocookie player.
   After embedding, clicks on the card text link out to YouTube (blocked-embed fallback). #}
<a class="entry-card video-card" href="https://youtu.be/{{ video.id }}" target="_blank" rel="noopener" data-video-id="{{ video.id }}" data-video-title="{{ video.title }}">
  <span class="video-thumb">
    <img src="https://i.ytimg.com/vi/{{ video.id }}/hqdefault.jpg" alt="Video preview: {{ video.title }}" loading="lazy">
    <span class="video-play" aria-hidden="true">▶</span>
  </span>
  <div class="entry-title">{{ video.cardTitle }}</div>
  <div>{{ video.blurb | safe }}</div>
  <div class="entry-meta">{{ video.meta }}</div>
</a>
<script>
if (!window.__videoCardInit) {
  window.__videoCardInit = true;
  document.addEventListener('click', function (e) {
    var card = e.target.closest('.video-card');
    if (!card || card.dataset.embedded) return;
    e.preventDefault();
    var frame = document.createElement('iframe');
    frame.src = 'https://www.youtube-nocookie.com/embed/' + card.dataset.videoId + '?autoplay=1';
    frame.allow = 'autoplay; encrypted-media; fullscreen';
    frame.title = card.dataset.videoTitle;
    card.querySelector('.video-thumb').replaceWith(frame);
    card.dataset.embedded = 'true';
  });
}
</script>
