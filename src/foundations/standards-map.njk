<p>Six of the nineteen competences are formally assessed this year; the rest are practiced throughout.</p>

<h2>The standards, one by one</h2>

<p>Every entry below matches what the tap-to-expand chips show on block pages — the plain-language version first, then the official wording, then where it runs, where it's assessed, and what being on track looks like.</p>

{% for sid, e in standardsCatalog %}
<section class="standard-entry" id="{{ sid | slugify }}">
  <h3>{{ sid }}{% if e.type == 'ngss-sep' %} — {{ e.official }}{% endif %}</h3>
  <p><strong>{{ e.plain }}</strong></p>
  {% if e.type != 'ngss-sep' %}<p class="std-official">{% if e.type == 'ailit' %}In brief: {% endif %}"{{ e.official }}"</p>{% endif %}
  {%- set trail = collections.standardsBlocks | standardsTrail(sid) %}
  {%- if trail.length %}
  <p><strong>Where this runs:</strong> {% for t in trail %}<a href="{{ t.url }}">U{{ t.unit }} B{{ t.block }}</a>{% if not loop.last %} · {% endif %}{% endfor %}</p>
  {%- endif %}
  <p><strong>Assessed:</strong> {{ e.assessedAt }}</p>
  <p><strong>On track looks like:</strong> {{ e.onTrack }}</p>
  {%- if e.help.length %}
  <p><strong>Help:</strong> {% for h in e.help %}{% if h.url %}<a href="{{ h.url }}">{{ h.label }}</a>{% else %}{{ h.label }}{% endif %}{% if not loop.last %} · {% endif %}{% endfor %}</p>
  {%- endif %}
</section>
{% endfor %}

