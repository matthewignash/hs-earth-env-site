        <img class="pg-disk" src="/assets/planets/planet-b.jpg" alt="Full-disk image of Planet B, unlabeled">
        <span class="pg-hint">Flip to reveal — after question 3</span>
      </div>
      <div class="pg-face pg-back">
        <span class="pg-name">TRAPPIST-1e</span>
        <span class="pg-origin artist">ARTIST'S IMPRESSION</span>
